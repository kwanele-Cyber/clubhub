<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Student Club Management{% endblock %}</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="{{ url_for('static', filename='css/style.css') }}">
    {% block extra_css %}{% endblock %}
</head>

<body>
    

    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container-fluid">
            <a class="navbar-brand" href="{{ url_for('clubs.list_clubs') }}">
                <i class="fas fa-users"></i> ClubManager
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    {% if current_user.is_authenticated %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ url_for('admin.dashboard') }}">
                            <i class="fas fa-tachometer-alt"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ url_for('clubs.list_clubs') }}">
                            <i class="fas fa-building"></i> Clubs
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ url_for('events.list_events') }}">
                            <i class="fas fa-calendar"></i> Events
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button"
                            data-bs-toggle="dropdown">
                            <i class="fas fa-user"></i> {{ current_user.first_name }}
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="{{ url_for('dashboard.profile') }}">Profile</a></li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li><a class="dropdown-item" href="{{ url_for('auth.logout') }}">Logout</a></li>
                        </ul>
                    </li>
                    {% else %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ url_for('auth.login') }}">Login</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ url_for('auth.register') }}">Register</a>
                    </li>
                    {% endif %}
                </ul>
            </div>
        </div>
    </nav>

    <!-- Flash Messages -->
    {% with messages = get_flashed_messages(with_categories=true) %}
    {% if messages %}
    <div class="container mt-3">
        {% for category, message in messages %}
        <div class="alert alert-{{ category }} alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        {% endfor %}
    </div>
    {% endif %}
    {% endwith %}

    <div class="container-fluid flex-grow-1 mt-1">
        <div class="row h-100">
            {% if current_user.is_authenticated %}
            <!-- Sidebar Column -->
            <div class="col-md-3 col-lg-2 p-1 sidebar-column d-none d-md-block">
                <div class="container-fluid">
                    <div class="row justify-content-md-center">
                        <div class="col-12 mb-3 d-flex align-items-center gap-2 mt-2">
                            <button class="btn btn-link text-muted p-0 border-0" id="mainMenuBtn" title="Main Menu">
                                <i class="fas fa-bars fa-lg"></i>
                            </button>
                            <div class="input-group input-group-sm rounded-pill border overflow-hidden bg-light flex-grow-1">
                                <span class="input-group-text bg-light border-0 px-2">
                                    <i class="fas fa-search text-muted"></i>
                                </span>
                                <input type="text" id="clubSearch" class="form-control border-0 bg-light px-1"
                                    placeholder="Search clubs..." aria-label="Search clubs" style="box-shadow: none;">
                            </div>
                        </div>
                        <div class="col-12 d-flex flex-row mb-1">
                            <span class="text-secondary fw-bold small">MY CLUBS</span>
                            <a href="{{ url_for('clubs.list_clubs') }}" class="btn btn-sm btn-link text-primary ms-auto p-0"
                                title="Browse all clubs">
                                <i class="fas fa-plus"></i>
                            </a>
                        </div>
                        {% if user_clubs %}
                        {% for sidebar_club in user_clubs %}
                        <a href="{{ url_for('clubs.view_club', club_id=sidebar_club.id) }}"
                            class="col-12 d-flex flex-row sidebar-item p-2 m-2 {% if club and club.id == sidebar_club.id %}active{% endif %}"
                            title="{{ sidebar_club.name }}">
                            {% if sidebar_club.logo_url %}
                            <img src="{{ sidebar_club.logo_url }}" class="rounded-circle">
                            {% else %}
                            <i class="col-2 fas fa-users"></i>
                            {% endif %}
                            <div class="club-info">
                                <div class="club-name">{{ sidebar_club.name }}</div>
                            </div>
                        </a>
                        {% endfor %}
                        {% else %}
                        <div class="col-12 d-flex flex-row p-2 m-2 text-center text-muted">
                            <p>No joined clubs yet.</p>
                            <a href="{{ url_for('clubs.list_clubs') }}" class="btn btn-sm btn-primary">Join a Club</a>
                        </div>
                        {% endif %}
                    </div>
                </div>
            </div>
            {% endif %}

            <!-- Main Content Column -->
            <div class="col p-0 content-column">
                <main class="p-4">
                    {% block content %}{% endblock %}

                    <!-- Footer -->
                    <footer class="bg-light text-center text-lg-start mt-5">
                        <div class="text-center p-3 text-muted">
                            © 2026 Student Club Management System
                        </div>
                    </footer>
                </main>
            </div>
        </div>
    </div>


    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <!-- Custom JS -->
    <script src="{{ url_for('static', filename='js/main.js') }}"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Club Search Logic
            const searchInput = document.getElementById('clubSearch');
            const clubItems = document.querySelectorAll('.sidebar-item');
            
            if (searchInput) {
                searchInput.addEventListener('input', function(e) {
                    const query = e.target.value.toLowerCase();
                    clubItems.forEach(item => {
                        const name = item.querySelector('.club-name').textContent.toLowerCase();
                        if (name.includes(query)) {
                            item.style.display = '';
                        } else {
                            item.style.setProperty('display', 'none', 'important');
                        }
                    });
                    
                    const visibleItems = document.querySelectorAll('.sidebar-item:not([style*="display: none"])');
                    const noClubsMessage = document.getElementById('noClubsMessage');
                    if (visibleItems.length === 0 && query !== '') {
                        if (!noClubsMessage) {
                            const msg = document.createElement('div');
                            msg.id = 'noClubsMessage';
                            msg.className = 'p-4 text-center text-muted small';
                            msg.textContent = 'No clubs found.';
                            document.querySelector('.row.justify-content-md-center').appendChild(msg);
                        }
                    } else if (noClubsMessage) {
                        noClubsMessage.remove();
                    }
                });
            }

            // Side Menu Toggle Logic
            const mainMenuBtn = document.getElementById('mainMenuBtn');
            const sideMenu = document.getElementById('sideMenu');
            const sideMenuOverlay = document.getElementById('sideMenuOverlay');

            if (mainMenuBtn && sideMenu && sideMenuOverlay) {
                mainMenuBtn.addEventListener('click', function() {
                    sideMenu.classList.add('show');
                    sideMenuOverlay.classList.add('show');
                });

                sideMenuOverlay.addEventListener('click', function() {
                    sideMenu.classList.remove('show');
                    sideMenuOverlay.classList.remove('show');
                });
            }
        });
    </script>
    {% block extra_js %}{% endblock %}
</body>

</html>